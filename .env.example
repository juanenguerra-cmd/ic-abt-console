# GEMINI_API_KEY is set in Cloudflare Pages dashboard → Settings → Environment variables
# It is NOT a frontend env var and must NOT be added here or in .env.local.

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ---------------------------------------------------------------------------
# Firebase Admin SDK — Cloud Functions credential configuration
# ---------------------------------------------------------------------------
# When deployed to Cloud Functions or Cloud Run, Application Default
# Credentials (ADC) are provided automatically by the managed environment.
# No service account key file is needed in production.
#
# For LOCAL development (outside the Firebase emulator), point this variable
# at a downloaded service account JSON key:
#   GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
#
# SECURITY: Never commit a service account key to source control.
# Add any key files to .gitignore and rotate them immediately if leaked.
#
# GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account-key.json"

# ---------------------------------------------------------------------------
# Firebase Client SDK Configuration
# ---------------------------------------------------------------------------
# These variables are required for the frontend to connect to Firebase.
# You can find these values in your Firebase Project Settings under "General" -> "Your apps".
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
